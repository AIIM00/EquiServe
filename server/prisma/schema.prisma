generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                String     @id @default(uuid())
  name              String
  email             String     @unique
  password          String
  phoneNumber       String?
  role              Role
  verifyOtp         String?
  isAccountVerified Boolean    @default(false)
  resetOtp          String?
  resetOtpExpireAt  DateTime?
  verifyOtpExpireAt DateTime?
  createdAt         DateTime   @default(now())
  //relations
  craftsman         Craftsman?
  location          Location?

  tasks        Task[]
  reviews      Review[]
  adminInvites AdminInvite[]

  sentWarnings Warning[]     @relation("AdminWarnings")
  applications Application[]
}

model AdminInvite {
  id        String   @id @default(uuid())
  email     String   @unique
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  used      Boolean  @default(false)

  createdBy String // Admin who created this invite
  creator   User   @relation(fields: [createdBy], references: [id])
}

model Craftsman {
  userId String @id
  user   User   @relation(fields: [userId], references: [id])

  categoryId String?
  queueOrder Int?

  experience Int?

  status       CraftsmanStatus @default(PENDING)
  isAvailable  Boolean         @default(true)
  warningLevel WarningLevel    @default(NONE)

  projects        Project[]
  assignments     TaskAssignment[]
  reviews         Review[]
  category        Category?        @relation(fields: [categoryId], references: [id])
  taskCompletions TaskCompletion[]

  warnings Warning[]
  tasks    Task[]

  @@unique([categoryId, queueOrder])
}

model Application {
  id String @id @default(uuid())

  userId String @unique
  user   User   @relation(fields: [userId], references: [id])

  // Step 1
  categoryId        String?
  yearsOfExperience Int?

  // Step 2
  city      String?
  address1  String?
  apartment String?

  // Step 3
  workingDays       Json?
  workingHours      Json?
  maxTravelDistance Int?

  // Step 4
  scenarioQA     Json?
  workBehaviorQA Json?

  // Progress tracking
  step   Int               @default(1)
  status ApplicationStatus @default(DRAFT)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category Category? @relation(fields: [categoryId], references: [id])
}

model Warning {
  id String @id @default(uuid())

  message   String
  createdAt DateTime @default(now())

  taskId String
  task   Task   @relation(fields: [taskId], references: [id])

  craftsmanId String
  craftsman   Craftsman @relation(fields: [craftsmanId], references: [userId])

  adminId String
  admin   User   @relation("AdminWarnings", fields: [adminId], references: [id])

  isRead Boolean @default(false)
}

model Location {
  id     String @id @default(uuid())
  userId String @unique

  city      String?
  address   String?
  apartment String?

  user User @relation(fields: [userId], references: [id])
}

model Category {
  id           String                   @id @default(uuid())
  name         String                   @unique
  craftsmen    Craftsman[]
  tasks        Task[]
  applications Application[]
  queue        CategoryAssignmentQueue?
}

model CategoryAssignmentQueue {
  categoryId     String   @id
  lastAssignedTo String?
  updatedAt      DateTime @updatedAt

  category Category @relation(fields: [categoryId], references: [id])
}

model Task {
  id          String  @id @default(uuid())
  categoryId  String
  userId      String
  craftsmanId String?

  title       String
  description String

  location String

  createdAt DateTime   @default(now())
  status    TaskStatus @default(PENDING)

  category        Category         @relation(fields: [categoryId], references: [id])
  user            User             @relation(fields: [userId], references: [id])
  craftsman       Craftsman?       @relation(fields: [craftsmanId], references: [userId])
  assignments     TaskAssignment[]
  reviews         Review[]
  taskCompletions TaskCompletion[]
  warnings        Warning[]
}

model TaskAssignment {
  id          String @id @default(uuid())
  taskId      String
  craftsmanId String

  status AssignmentStatus @default(PENDING)

  assignedAt  DateTime  @default(now())
  respondedAt DateTime?

  task      Task      @relation(fields: [taskId], references: [id])
  craftsman Craftsman @relation(fields: [craftsmanId], references: [userId])

  @@unique([taskId, craftsmanId])
}

model Review {
  id String @id @default(uuid())

  taskId      String
  userId      String
  craftsmanId String

  rating    Int
  comment   String?
  createdAt DateTime @default(now())

  task      Task      @relation(fields: [taskId], references: [id])
  craftsman Craftsman @relation(fields: [craftsmanId], references: [userId])
  user      User?     @relation(fields: [userId], references: [id])

  //npx prisma migrate dev --name add_unique_review_constraint
  @@unique([taskId, userId])
}

model Project {
  id          String @id @default(uuid())
  craftsmanId String

  title       String
  description String

  createdAt DateTime @default(now())

  craftsman Craftsman      @relation(fields: [craftsmanId], references: [userId])
  images    ProjectImage[]
}

model ProjectImage {
  id        String @id @default(uuid())
  projectId String

  imageUrl String

  project Project @relation(fields: [projectId], references: [id])
}

model TaskCompletion {
  id          String   @id @default(uuid())
  taskId      String   @unique
  craftsmanId String
  notes       String?
  completedAt DateTime @default(now())

  craftsman Craftsman   @relation(fields: [craftsmanId], references: [userId])
  task      Task        @relation(fields: [taskId], references: [id])
  images    TaskImage[]
}

model TaskImage {
  id               String @id @default(uuid())
  taskCompletionId String
  imageUrl         String

  completion TaskCompletion @relation(fields: [taskCompletionId], references: [id])
}

enum Role {
  CUSTOMER
  CRAFTSMAN
  SUPERADMIN
  ADMIN
}

enum TaskStatus {
  PENDING
  WAITING
  IN_PROGRESS
  COMPLETED
}

enum AssignmentStatus {
  PENDING
  ACCEPTED
  DECLINED
  TIMEOUT
}

enum CraftsmanStatus {
  SUSPENDED
  PENDING
  APPROVED
  REJECTED
}

enum WarningLevel {
  NONE
  LOW
  MEDIUM
  HIGH
}

enum ApplicationStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
}
